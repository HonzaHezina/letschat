# Copy this file to .env.local and fill values for local development
# Public keys (safe to use in frontend during development)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (HIGHLY SENSITIVE)
# This key has elevated privileges and must never be committed to source control.
# Use it only for local testing of server-side functions or when calling RPCs that require
# full DB permissions. Prefer setting this as an environment variable in your shell/CI.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
